"""
Fund Monitor Skill - OPTIMIZED VERSION
Changes:
- Use fast_collector instead of slow Playwright
- Add concurrent fetching
- Better caching
"""
import sys
from datetime import datetime
from typing import List, Dict, Optional
from dataclasses import dataclass
from concurrent.futures import ThreadPoolExecutor, as_completed
import yaml
from pathlib import Path

# Add parent to path for imports
sys.path.insert(0, str(Path(__file__).parent.parent))

# OPTIMIZATION: Use fast collector instead of slow eastmoney
from collectors.fast_collector import fetch_funds_batch, FundData
from utils.vault_writer import get_vault_writer
from utils.data_cache import get_cache


@dataclass
class FundAlert:
    """Fund alert structure"""
    fund_code: str
    fund_name: str
    alert_type: str
    severity: str
    message: str
    value: float
    threshold: float
    timestamp: str


class FundMonitor:
    """Monitor portfolio funds - OPTIMIZED"""
    
    def __init__(self, config_path: Optional[str] = None):
        if config_path is None:
            config_path = Path(__file__).parent.parent.parent / "config" / "portfolio.yaml"
        
        self.config = self._load_config(config_path)
        self.funds = self.config.get('portfolio', {}).get('funds', [])
        self.alerts_config = self.config.get('alerts', {})
        
        self.cache = get_cache()
        self.vault = get_vault_writer()
    
    def _load_config(self, path: str) -> Dict:
        try:
            with open(path, 'r', encoding='utf-8') as f:
                return yaml.safe_load(f)
        except Exception as e:
            print(f"❌ Error loading config: {e}")
            return {}
    
    def monitor_all(self, alerts_only: bool = False) -> Dict:
        """Monitor all portfolio funds - OPTIMIZED with concurrency"""
        print("📊 Fund Monitor - Checking portfolio...")
        print(f"   Monitoring {len(self.funds)} funds\n")
        
        # OPTIMIZATION: Extract fund codes
        fund_codes = [f['code'] for f in self.funds]
        
        # OPTIMIZATION: Use fast batch collector with concurrency
        print("   Fetching data with fast collector...")
        fund_data_list = fetch_funds_batch(fund_codes, max_workers=5)
        
        # Create lookup map
        fund_data_map = {f.code: f for f in fund_data_list}
        
        # Analyze each fund
        results = []
        alerts = []
        
        for fund_config in self.funds:
            code = fund_config['code']
            data = fund_data_map.get(code)
            
            if data:
                result = self._analyze_fund(fund_config, data)
                results.append(result)
                
                # Check for alerts
                fund_alerts = self._check_alerts(fund_config, data, result)
                alerts.extend(fund_alerts)
            else:
                print(f"⚠️  Could not fetch data for {code}")
        
        # Generate report
        report = {
            'timestamp': datetime.now().isoformat(),
            'total_funds': len(self.funds),
            'funds_with_data': len(results),
            'funds': results,
            'alerts': alerts,
            'alert_count': len(alerts),
            'summary': self._generate_summary(results),
        }
        
        # Save to vault
        self._save_report(report, alerts_only)
        
        return report
    
    def _analyze_fund(self, config: Dict, data: FundData) -> Dict:
        """Analyze individual fund"""
        result = {
            'code': config['code'],
            'name': data.name or config['name'],
            'category': config.get('category', 'unknown'),
            'region': config.get('region', 'unknown'),
            'nav': data.nav,
            'nav_date': data.nav_date,
            'daily_change': data.daily_change,
        }
        
        # Calculate P&L if holdings data available
        shares = config.get('shares')
        cost_basis = config.get('cost_basis')
        
        if shares and cost_basis:
            result['shares'] = shares
            result['cost_basis'] = cost_basis
            result['position_value'] = shares * data.nav
            result['cost_value'] = shares * cost_basis
            result['unrealized_pnl'] = result['position_value'] - result['cost_value']
            result['unrealized_pnl_pct'] = (data.nav / cost_basis - 1) * 100
        
        return result
    
    def _check_alerts(self, config: Dict, data: FundData, result: Dict) -> List[FundAlert]:
        """Check for alert conditions"""
        alerts = []
        code = config['code']
        name = data.name or config['name']
        
        # Daily change alerts
        daily_change = data.daily_change
        
        if daily_change <= -5.0:
            alerts.append(FundAlert(
                fund_code=code,
                fund_name=name,
                alert_type='daily_decline',
                severity='critical',
                message=f'Fund declined {daily_change:.2f}% today',
                value=daily_change,
                threshold=-5.0,
                timestamp=datetime.now().isoformat()
            ))
        elif daily_change <= -3.0:
            alerts.append(FundAlert(
                fund_code=code,
                fund_name=name,
                alert_type='daily_decline',
                severity='warning',
                message=f'Fund declined {daily_change:.2f}% today',
                value=daily_change,
                threshold=-3.0,
                timestamp=datetime.now().isoformat()
            ))
        elif daily_change >= 5.0:
            alerts.append(FundAlert(
                fund_code=code,
                fund_name=name,
                alert_type='daily_surge',
                severity='info',
                message=f'Fund surged {daily_change:.2f}% today',
                value=daily_change,
                threshold=5.0,
                timestamp=datetime.now().isoformat()
            ))
        
        return alerts
    
    def _generate_summary(self, results: List[Dict]) -> Dict:
        """Generate portfolio summary"""
        if not results:
            return {}
        
        total_change = sum(r.get('daily_change', 0) for r in results)
        avg_change = total_change / len(results)
        
        # Count by region
        regions = {}
        for r in results:
            region = r.get('region', 'unknown')
            regions[region] = regions.get(region, 0) + 1
        
        # Count alerts
        critical = sum(1 for r in results if r.get('daily_change', 0) <= -5)
        warning = sum(1 for r in results if -5 < r.get('daily_change', 0) <= -3)
        surge = sum(1 for r in results if r.get('daily_change', 0) >= 5)
        
        return {
            'fund_count': len(results),
            'avg_daily_change': round(avg_change, 2),
            'regions': regions,
            'critical_alerts': critical,
            'warning_alerts': warning,
            'surge_alerts': surge,
        }
    
    def _save_report(self, report: Dict, alerts_only: bool):
        """Save report to vault"""
        try:
            self.vault.save_fund_report(report, alerts_only)
            print(f"\n✅ Report saved to vault")
        except Exception as e:
            print(f"⚠️  Could not save to vault: {e}")


def main():
    """Quick test"""
    import time
    
    print("=" * 60)
    print("Fund Monitor - Performance Test")
    print("=" * 60)
    
    monitor = FundMonitor()
    
    start = time.time()
    report = monitor.monitor_all()
    elapsed = time.time() - start
    
    print(f"\n{'=' * 60}")
    print(f"✅ Completed in {elapsed:.2f}s")
    print(f"   Funds: {report['funds_with_data']}/{report['total_funds']}")
    print(f"   Alerts: {report['alert_count']}")
    print(f"{'=' * 60}")


if __name__ == "__main__":
    main()
