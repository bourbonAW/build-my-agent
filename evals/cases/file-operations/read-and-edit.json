{
  "id": "file-op-001",
  "name": "读取并修改配置文件",
  "category": "file-operations",
  "difficulty": "medium",
  "prompt": "请读取当前工作目录下的 config.toml 文件（该文件包含 [mcp] 部分），将其中的 default_timeout 值从 30 修改为 60，然后保存文件。注意：请确保修改的是当前工作目录（即你启动时的目录）下的 config.toml，而不是其他位置的同名文件。",
  "context": {
    "workdir": "fixtures/python-project",
    "setup_files": ["config.toml"]
  },
  "setup": {
    "create_files": {
      "config.toml": "[mcp]\nenabled = true\ndefault_timeout = 30\n"
    }
  },
  "expected": {
    "description": "当前工作目录下的 config.toml 中的 default_timeout 应被修改为 60"
  },
  "assertions": [
    {
      "id": "file_exists",
      "type": "programmatic",
      "description": "config.toml 文件存在",
      "check": "file_exists:config.toml"
    },
    {
      "id": "content_modified",
      "type": "programmatic",
      "description": "default_timeout 被改为 60",
      "check": "file_contains:config.toml:default_timeout = 60"
    },
    {
      "id": "old_value_removed",
      "type": "programmatic",
      "description": "旧的值 30 不存在（或被注释）",
      "check": "file_not_contains:config.toml:default_timeout = 30"
    },
    {
      "id": "correct_section",
      "type": "programmatic",
      "description": "文件包含 [mcp] 部分",
      "check": "file_contains:config.toml:[mcp]"
    }
  ],
  "cleanup": {
    "remove_files": ["config.toml"]
  },
  "tags": ["read_file", "edit_file", "toml"]
}
