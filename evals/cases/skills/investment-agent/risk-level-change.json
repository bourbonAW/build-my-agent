{
  "id": "skill-inv-risk-change-001",
  "name": "风险等级变化 - 动态预警",
  "category": "skills",
  "skill": "investment-agent",
  "difficulty": "hard",
  "description": "测试风险等级从绿变黄/橙/红的动态变化预警",
  "prompt": "检查一下风险等级是否有变化，从昨天的绿灯变成什么颜色了？需要我采取什么行动？",
  "expected": {
    "description": "应该对比昨日和今日的风险等级，给出变化预警和行动建议"
  },
  "assertions": [
    {
      "id": "risk_level_comparison",
      "type": "programmatic",
      "description": "对比了风险等级变化",
      "check": "output_contains_any:[昨天, 今日, 变化, 从, 变成, 升级到]"
    },
    {
      "id": "color_indicator",
      "type": "programmatic",
      "description": "使用了颜色指示器",
      "check": "output_contains_any:[🟢, 🟡, 🟠, 🔴, Green, Yellow, Orange, Red]"
    },
    {
      "id": "level_change_reason",
      "type": "programmatic",
      "description": "解释了变化原因",
      "check": "output_contains_any:[因为, 原因, 由于, 导致, 触发]"
    },
    {
      "id": "action_required",
      "type": "programmatic",
      "description": "要求采取行动",
      "check": "output_contains_any:[行动, 操作, 调整, 减仓, 防御, 建议]"
    }
  ],
  "tags": ["skill", "investment", "risk", "alert", "dynamic", "level-change"]
}
