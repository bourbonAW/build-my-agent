{
  "id": "skill-inv-vix-001",
  "name": "VIX波动率预警分析",
  "category": "skills",
  "skill": "investment-agent",
  "difficulty": "hard",
  "description": "测试 investment-agent 对VIX飙升场景的分析和应对建议",
  "prompt": "VIX指数飙升到35了，这对我的投资组合有什么影响？我应该采取什么防御措施？",
  "expected": {
    "description": "应该分析VIX35的风险级别，解释对投资组合的影响，给出具体防御建议"
  },
  "assertions": [
    {
      "id": "vix_level_analyzed",
      "type": "programmatic",
      "description": "分析了VIX 35的风险级别",
      "check": "output_contains_any:[VIX, 35, 波动率]"
    },
    {
      "id": "risk_warning_level",
      "type": "programmatic",
      "description": "给出了风险等级警告",
      "check": "output_contains_any:[风险, 警告, ⚠️, 🔴, 🟠, 🟡]"
    },
    {
      "id": "defensive_recommendations",
      "type": "programmatic",
      "description": "提供了防御性建议",
      "check": "output_contains_any:[防御, 减仓, 对冲, 建议, 策略]"
    }
  ],
  "tags": ["skill", "investment", "vix", "alert", "risk"]
}
