{
  "id": "skill-inv-fund-001",
  "name": "基金监控 - 查询单只基金表现",
  "category": "skills",
  "skill": "investment-agent",
  "difficulty": "medium",
  "description": "测试 investment-agent 是否能正确查询并分析单只基金的表现",
  "prompt": "帮我查询一下019455中韩半导体ETF今天的表现，包括涨跌幅、净值和交易量",
  "expected": {
    "description": "应该返回019455基金的今日表现数据，包含涨跌幅、净值等信息"
  },
  "assertions": [
    {
      "id": "fund_code_mentioned",
      "type": "programmatic",
      "description": "提到了基金代码019455",
      "check": "output_contains:019455"
    },
    {
      "id": "price_change_info",
      "type": "programmatic",
      "description": "包含涨跌幅信息",
      "check": "output_contains_any:[涨跌幅, %, 涨跌]"
    },
    {
      "id": "net_value_info",
      "type": "programmatic",
      "description": "包含净值信息",
      "check": "output_contains_any:[净值, 单位净值]"
    }
  ],
  "tags": ["skill", "investment", "fund", "monitor"]
}
